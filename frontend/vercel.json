{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://splitsnap-wrrg.onrender.com/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://splitsnap-wrrg.onrender.com/socket.io/:path*"
    },
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
